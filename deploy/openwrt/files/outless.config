config outless 'app'
	option http_port '41220'
	option external_host 'localhost'
	option log_level 'info'
	option singbox_log_level 'warn'
	option disable_docs '1'
	option pprof_enabled '0'
	option pprof_bind '127.0.0.1:6060'

config outless 'jwt'
	option secret ''
	option expiry '24h'

config outless 'database'
	option path '/etc/outless/outless.db'
